{
    "name": "seo-doctor",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev --turbopack",
        "build": "next build",
        "start": "next start",
        "lint": "next lint",
        "initialize": "dotenv -e .env -- tsx scripts/initialize.ts",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "required:generate-stripe": "dotenv -e .env -- tsx scripts/required-generate-stripe.ts",
        "required:seed-database": "dotenv -e .env -- tsx scripts/required-seed-database.ts",
        "test:seed-user": "dotenv -e .env -- tsx scripts/test-seed-user.ts",
        "test:seed-data": "dotenv -e .env -- tsx scripts/test-seed-data.ts",
        "test:seed-admin": "dotenv -e .env -- tsx scripts/test-seed-admin.ts",
        "db:drop": "dotenv -e .env -- tsx scripts/drop-database.ts",
        "db:fix-indexes": "dotenv -e .env -- tsx scripts/fix-indexes.ts"
    },
    "dependencies": {
        "@libsql/client": "^0.17.0",
        "@stripe/react-stripe-js": "^5.6.1",
        "@stripe/stripe-js": "^8.9.0",
        "@tsparticles/engine": "^3.9.1",
        "@tsparticles/react": "^3.0.0",
        "@tsparticles/slim": "^3.9.1",
        "bcryptjs": "^3.0.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cookies-next": "^6.1.1",
        "crypto-js": "^4.2.0",
        "date-fns": "^4.1.0",
        "dotenv": "^17.3.1",
        "drizzle-orm": "^0.45.1",
        "framer-motion": "^12.34.5",
        "lucide-react": "^0.576.0",
        "next": "16.1.6",
        "nodemailer": "^8.0.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "stripe": "^20.4.0",
        "tailwind-merge": "^3.5.0",
        "uuid": "^13.0.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3",
        "@tailwindcss/postcss": "^4",
        "@types/crypto-js": "^4.2.2",
        "@types/node": "^25",
        "@types/nodemailer": "^7.0.11",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "dotenv-cli": "^11.0.0",
        "drizzle-kit": "^0.31.9",
        "eslint": "^10",
        "eslint-config-next": "16.1.6",
        "tailwindcss": "^4",
        "tsx": "^4.21.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5"
